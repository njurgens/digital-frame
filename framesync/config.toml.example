# Copy this file to config.toml and fill in your values.
# config.toml is excluded from version control (contains secrets).

# OneDrive shared folder URL
share_url = "https://1drv.ms/f/YOUR_SHARE_URL_HERE"

# Password for the shared folder (if set)
password = "your-password-here"

# Local directory to sync images into
output_dir = "/home/frame/Pictures/slideshow"

# Directory for pre-rendered surface cache (speeds up second+ cycles)
cache_dir = "/home/frame/.cache/framesync"

# Seconds each image is displayed (excluding the crossfade)
display_duration = 60

# Seconds for the crossfade transition between images
transition_duration = 1.5

# Seconds after an image appears before background preloading of the next starts.
# This avoids a CPU spike at transition time and gives framesync a sync window.
preload_delay = 3
